    <string name="dashboard_info_title">Dashboard</string>
    <string name="dashboard_info">• Tap a device action to run it\n• Choose list or widget view\n• Arrows change the order\n• The X at the bottom right cancels a running action\n• Action details: tap the compact bar to open it, or its title to minimize it\n• Green: Wi-Fi connection confirmed\n• Red: a specific Wi-Fi connection attempt failed\n• Gray: Wi-Fi not yet confirmed, no assignment, or detection unavailable\n• A visible SSID does not confirm a connection\n• The menu opens settings and help</string>
    <string name="settings_info">• Wi-Fi profiles: manage credentials\n• Devices: define actions and Wi-Fi assignments\n• System: appearance and action details\n• Backup: save or import configuration</string>
    <string name="system_info_title">System</string>
    <string name="system_info">• Choose appearance and language\n• Show or hide action details</string>
    <string name="backup_info">• Export saves the local configuration\n• Export passwords only deliberately\n• Import only from trusted sources</string>
    <string name="password_storage_info">Wi-Fi passwords are stored encrypted on this device. They are not sent to a cloud service and are not shown in action details.</string>
    <string name="hostname_ip_info">Enter the device\'s local address in its assigned Wi-Fi network, for example 192.168.33.1 or a hostname resolved on the local network. No internet connection is required.</string>
    <string name="api_call_info">The HTTP/RPC call is appended to the local device address. Use only a path supported by the device, for example /relay/0?turn=on.</string>
    <string name="action_details_info">• Shows Wi-Fi connection, timeout, and HTTP status\n• The X at the bottom right cancels the running action\n• Tap the compact bar to open it\n• Tap the Action details title in the open panel to minimize it\n• Local progress only\n• Passwords are not logged</string>
    <string name="wifi_profiles_info_title">Manage Wi-Fi profiles</string>
    <string name="devices_info_title">Manage devices</string>
    <string name="list_interaction_info">• Use + to add an entry\n• Tap an entry to edit it\n• Swipe left or right to delete it\n• Confirm deletion afterwards</string>
    <string name="wifi_profile_dialog_info_title">Wi-Fi profile</string>
    <string name="wifi_profile_dialog_info">• Enter the target Wi-Fi SSID\n• The name must be unique\n• The password remains encrypted on the device</string>
    <string name="device_dialog_info_title">Device</string>
    <string name="device_dialog_info">• Set the name and button label\n• Enter the HTTP/RPC method and path\n• Wi-Fi assignments define the connection order</string>
    <string name="wifi_assignment_dialog_info_title">Wi-Fi assignment</string>
    <string name="wifi_assignment_dialog_info">• Select a Wi-Fi profile for the device\n• Enter the local device address\n• No internet access is required</string>
    <string name="about_switchwerk">About SwitchWerk</string>
    <string name="about_description">SwitchWerk controls Shelly and other devices directly on the local network. The configuration remains on this device.</string>
    <string name="version_value">Version %1$s</string>
    <string name="release_date">Released 23 June 2026</string>
    <string name="about_author">Developed by spi</string>
    <string name="about_license">License: GNU AGPL-3.0-or-later</string>
    <string name="open_github_project">Open GitHub project</string>
    <string name="help_getting_started_title">Setup</string>
    <string name="help_getting_started_text">• Create a Wi-Fi profile\n• Add a device with address and API call\n• Run the action</string>
    <string name="help_connection_title">Connection and troubleshooting</string>
    <string name="help_connection_text">• The status point confirms a Wi-Fi connection, not physical Wi-Fi proximity\n• Green: Wi-Fi connection confirmed\n• Red: Android could not establish the specific Wi-Fi request\n• Gray: Wi-Fi not yet confirmed, no assignment, or detection unavailable\n• A visible SSID alone does not confirm a connection\n• The X at the bottom right cancels a running action and its Wi-Fi request\n• Android\'s system dialog cannot be closed by SwitchWerk\n• A device access point may interrupt internet access\n• HTTP errors come from the device</string>
    <string name="help_privacy_title">Permissions and privacy</string>
    <string name="help_privacy_text">• Local operation only\n• No accounts, cloud, or tracking\n• Wi-Fi and location permissions only for Wi-Fi features</string>

